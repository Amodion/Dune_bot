# dune-bot environment example.
# The application does not load this file automatically.
# Runtime values should come from Vercel Project Settings or the local shell.

SERVICE_NAME=dune-bot
SERVICE_VERSION=0.2.0
LOG_LEVEL=INFO
LOG_FILE=dune_bot.log
LOG_BACKUP_COUNT=14
LOG_ENABLE_FILE=false
API_V1_PREFIX=/api/v1
HEALTH_MESSAGE=Long Live The Fighters!

# Telegram BotFather token. Never commit the real value.
TELEGRAM_BOT_TOKEN=

# Secret path segment used by /telegram/webhook/{secret}.
TELEGRAM_WEBHOOK_PATH_SECRET=replace-with-random-path-secret

# Optional Telegram setWebhook secret_token; Telegram sends it as
# X-Telegram-Bot-Api-Secret-Token.
TELEGRAM_WEBHOOK_SECRET_TOKEN=

# Public Vercel or tunnel base URL, without trailing slash.
PUBLIC_BASE_URL=https://your-project.vercel.app
